<div
  data-controller="dropdown"
  data-dropdown-name-value="<%= @name %>"
  data-dropdown-autosubmit-value="<%= @autosubmit %>"
  class="relative <%= @class %>"
  data-dropdown-hidden-class="hidden"
  data-dropdown-open-class="open"
  data-dropdown-selected-class="font-bold"
>
  <button
    type="button"
    data-action="click->dropdown#toggle"
    class="
      md:flex items-center w-full px-4 py-2 border border-beige-500 rounded-lg
      shadow-sm bg-white text-gray-900 justify-between
    "
  >
    <span data-dropdown-target="label">
      <%= @label %>
    </span>
    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"
      />
    </svg>
  </button>
  <div
    data-dropdown-target="menu"
    class="
      hidden dropdown-animate absolute z-10 mt-2 min-w-[12rem] bg-white rounded-xl
      shadow-lg border divide-y divide-gray-100
    "
  >
    <% @options.each_with_index do |option, idx| %>
      <% label, value = option.is_a?(Array) ? option : [option, option] %>
      <% rounded_class = "" %>
      <% rounded_class += " rounded-t-xl" if idx == 0 %>
      <% rounded_class += " rounded-b-xl" if idx == @options.size - 1 %>
      <button
        type="button"
        data-action="dropdown#select"
        data-value="<%= value %>"
        class="
          block w-full text-left px-5 py-3 text-gray-800 hover:bg-gray-50 transition
          rounded-none<%= rounded_class %><%= value == @selected ? ' font-bold' : '' %>
        "
      >
        <%= label %>
      </button>
    <% end %>
    <input
      type="hidden"
      name="<%= @name %>"
      id="<%= @name %>"
      value="<%= @selected %>"
      data-dropdown-target="hiddenInput"
    />
  </div>
</div>
