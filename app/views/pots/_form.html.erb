<%= form_with(model: pot, class: "contents") do |form| %>
  <% if pot.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(pot.errors.count, "error") %> prohibited this pot from being saved:</h2>

      <ul class="list-disc ml-6">
        <% pot.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pot.errors[:name].none?, "border-red-400 focus:outline-red-600": pot.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :target %>
    <%= form.text_field :target, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pot.errors[:target].none?, "border-red-400 focus:outline-red-600": pot.errors[:target].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :total %>
    <%= form.text_field :total, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pot.errors[:total].none?, "border-red-400 focus:outline-red-600": pot.errors[:total].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :theme %>
    <%= form.text_field :theme, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pot.errors[:theme].none?, "border-red-400 focus:outline-red-600": pot.errors[:theme].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
