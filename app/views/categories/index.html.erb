<% content_for :title, "Categories" %>

<div class="px-4 py-6 md:px-10 md:py-8">
  <div class="max-w-4xl mx-auto space-y-10">

    <div class="flex justify-between items-center">
      <h1 class="text-gray-900 text-3xl font-bold leading-10">Categories</h1>
      <%= link_to "New Category", new_category_path, class: "btn btn--primary" %>
    </div>

    <% if notice.present? %>
      <p
        class="
          py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block
        "
        id="notice"
      >
        <%= notice %>
      </p>
    <% end %>

    <div class="bg-white rounded-2xl shadow-md p-4 md:p-8">
      <table class="w-full text-left">
        <thead class="text-sm text-neutral-500">
          <tr>
            <th>Name</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @categories.each do |category| %>
            <tr class="border-b border-gray-100">
              <td class="py-4"><%= category.name %></td>
              <td class="py-4 text-right">
                <%= link_to "Edit",
                edit_category_path(category),
                class: "text-blue-500 hover:underline" %>
                <%= link_to "Delete",
                category_path(category),
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "Are you sure?",
                },
                class: "text-red-500 hover:underline ml-4" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
