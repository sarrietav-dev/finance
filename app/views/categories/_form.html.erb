<%= form_with(model: category, html: { class: "space-y-6" }) do |form| %>
  <% if category.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-700 p-4 rounded-md">
      <h2 class="text-lg font-bold mb-2"><%= pluralize(category.errors.count, "error") %>
        prohibited this category from being saved:</h2>

      <ul class="list-disc list-inside">
        <% category.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name,
                    class:
                      "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>

  <div class="flex justify-end">
    <%= form.submit class: "btn btn--primary" %>
  </div>
<% end %>
