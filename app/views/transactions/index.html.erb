<% content_for :title, "Transactions" %>

<div class="px-4 py-6 md:px-10 md:py-8">
  <div class="max-w-4xl mx-auto space-y-10">

    <h1 class="text-gray-900 text-3xl font-bold leading-10">Transactions</h1>
    <section class="bg-white rounded-2xl shadow-md p-4 md:p-8">

      <% if notice.present? %>
        <p
          class="
            py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block
          "
          id="notice"
        >
          <%= notice %>
        </p>
      <% end %>
      <!-- Filter/Search Section -->
      <div class="flex items-center justify-between gap-4 mb-6 ">
        <form
          method="get"
          action="/transactions"
          data-turbo-frame="transaction_table"
          data-turbo-stream="true"
          class="grow md:max-w-sm"
        >
          <label class="sr-only" for="search">Search transactions</label>
          <input
            type="search"
            name="search"
            id="search"
            value="<%= params[:search] %>"
            placeholder="Search transactions..."
            class="w-full border rounded-md p-2"
          />
        </form>
        <div class="flex justify-end gap-4">

          <%= form_with url: "/transactions", method: :get, data: { turbo_stream: true, turbo: true } do |form| %>
            <%= form.select :sort,
                        options_for_select(
                          [%w[Latest desc], %w[Oldest asc]],
                          params[:sort],
                        ),
                        {},
                        {
                          class:
                            "flex items-center w-full pl-4 pr-10 py-2 border border-beige-500 rounded-lg shadow-sm bg-white text-gray-900 justify-between",
                          onchange: "this.form.requestSubmit()",
                        } %>

            <%= form.select :category,
                        options_for_select(
                          [
                            ["All Transactions", "all"],
                            %w[Entertainment entertainment],
                            %w[Bills bills],
                            %w[Groceries groceries],
                            ["Dining Out", "dining_out"],
                            %w[Transportation transportation],
                            ["Personal Care", "personal_care"],
                          ],
                          params[:category],
                        ),
                        {},
                        {
                          class:
                            "flex items-center w-full pl-4 pr-10 py-2 border border-beige-500 rounded-lg shadow-sm bg-white text-gray-900 justify-between",
                          onchange: "this.form.requestSubmit()",
                        } %>
          <% end %>
        </div>
      </div>

      <turbo-frame id="transaction_table">
        <%= render partial: "transactions/table",
        locals: {
          transactions: @transactions,
          pagy: @pagy,
        } %>
      </turbo-frame>
    </section>
  </div>
</div>
