<% content_for :title, "Transactions" %>

<div class="px-4">
  <section class="max-w-4xl mx-auto bg-white rounded-2xl shadow-md p-4 md:p-8">

    <% if notice.present? %>
      <p
        class="
          py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block
        "
        id="notice"
      >
        <%= notice %>
      </p>
    <% end %>
    <h1 class="text-2xl font-bold mb-6">Transactions</h1>
    <!-- Filter/Search Section -->
    <div class="flex items-center justify-between gap-4 mb-6 ">
      <div class="grow md:max-w-sm">
        <label class="sr-only" for="search">Search transactions</label>
        <input
          type="search"
          id="search"
          placeholder="Search transactions..."
          class="w-full border rounded-md p-2"
        />
      </div>

      <div class="flex justify-end gap-4">
        <div class="hidden md:flex items-center gap-2">
          <label for="sort" class="text-nowrap">Sort by</label>
          <select id="sort" class="border rounded-md p-2 w-full" aria-label="Sort by">
            <option value="latest">Latest</option>
            <option value="oldest">Oldest</option>
          </select>
        </div>

        <div class="hidden md:flex items-center gap-2">
          <label for="category">
            Category
          </label>
          <select
            id="category"
            class="border rounded-md p-2 w-full"
            aria-label="Filter by category"
          >
            <option value="all">All Transactions</option>
            <option value="general">General</option>
            <option value="personal-care">Personal Care</option>
            <option value="lifestyle">Lifestyle</option>
            <option value="transportation">Transportation</option>
          </select>
        </div>

        <div
          data-controller="dropdown"
          class="relative inline-block text-left md:hidden"
        >
          <!-- Trigger Icon -->
          <button
            type="button"
            data-action="click->dropdown#toggle"
            class="
              flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100
              focus:outline-none focus:ring-2 focus:ring-indigo-500 transition
            "
          >
            <span>
              <%= inline_svg_tag "icon-sort-mobile.svg" %>
            </span>
          </button>
          <!-- Dropdown Menu -->
          <div
            data-dropdown-target="menu"
            class="
              hidden absolute right-0 mt-2 w-48 origin-top-right rounded-xl shadow-lg bg-white
              ring-1 ring-black ring-opacity-5 z-50 transition ease-out duration-100
            "
          >
            <div class="py-2" role="menu">
              <%= link_to "Editar",
              "#",
              role: "menuitem",
              class:
                "block px-4 py-2 text-sm text-gray-700 hover:bg-indigo-100 hover:text-indigo-700 transition" %>
              <%= link_to "Eliminar",
              "#",
              role: "menuitem",
              class:
                "block px-4 py-2 text-sm text-red-600 hover:bg-red-100 hover:text-red-700 transition" %>
            </div>
          </div>
        </div>
        <div
          data-controller="dropdown"
          class="relative inline-block text-left md:hidden"
        >
          <!-- Trigger Icon -->
          <button
            type="button"
            data-action="click->dropdown#toggle"
            class="
              flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100
              focus:outline-none focus:ring-2 focus:ring-indigo-500 transition
            "
          >
            <span>
              <%= inline_svg_tag "icon-filter-mobile.svg" %>
            </span>
          </button>
          <!-- Dropdown Menu -->
          <div
            data-dropdown-target="menu"
            class="
              hidden absolute right-0 mt-2 w-48 origin-top-right rounded-xl shadow-lg bg-white
              ring-1 ring-black ring-opacity-5 z-50 transition ease-out duration-100
            "
          >
            <div class="py-2" role="menu">
              <%= link_to "Editar",
              "#",
              role: "menuitem",
              class:
                "block px-4 py-2 text-sm text-gray-700 hover:bg-indigo-100 hover:text-indigo-700 transition" %>
              <%= link_to "Eliminar",
              "#",
              role: "menuitem",
              class:
                "block px-4 py-2 text-sm text-red-600 hover:bg-red-100 hover:text-red-700 transition" %>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Transactions Table (Desktop) -->
    <% if @transactions.any? %>
      <div class="hidden md:block">
        <table class="w-full text-left border-separate border-spacing-y-3">
          <thead class="text-sm text-neutral-500">
            <tr>
              <th>Recipient / Sender</th>
              <th>Category</th>
              <th>Transaction Date</th>
              <th class="text-right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% @transactions.each do |t| %>
              <tr>
                <td class="font-semibold">
                  <%= t.name %>
                </td>
                <td>
                  <%= t.category %>
                </td>
                <td>
                  <%= l(t.date, format: :short) %>
                </td>
                <td class="text-right text-red-600 font-semibold">
                  -$<%= t.amount %>
                </td>
              </tr>
              <tr>
                <td colspan="4">
                  <hr class="border-0 border-t border-gray-100 m-0 my-3">
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <!-- Transactions List (Mobile) -->
      <ul class="md:hidden flex flex-col divide-y divide-gray-100">

        <% @transactions.each do |t| %>
          <li class="p-4 flex justify-between items-center">

            <div>
              <p class="font-semibold">
                <%= t.name %>
              </p>
              <p class="text-sm text-neutral-500">
                <%= t.category %>
              </p>
            </div>
            <div class="text-right">
              <p class="text-red-600 font-semibold">
                -$<%= t.amount %>
              </p>
              <p class="text-sm text-neutral-500">
                <%= l(t.date, format: :short) %>
              </p>
            </div>
          </li>
        <% end %>
        <!-- Add more list items similarly -->
      </ul>
    <% else %>
      <p aria-label="No transactions found" class="text-center my-10">No transactions found.</p>
    <% end %>

  </section>
</div>
