<% content_for :title, "Transactions" %>

<div class="px-4">
  <section class="max-w-4xl mx-auto bg-white rounded-2xl shadow-md p-4 md:p-8">

    <% if notice.present? %>
      <p
        class="
          py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block
        "
        id="notice"
      ><%= notice %></p>
    <% end %>
    <h1 class="text-2xl font-bold mb-6">Transactions</h1>
    <!-- Filter/Search Section -->
    <div
      class="
        flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6
      "
    >
      <label class="sr-only" for="search">Search transactions</label>
      <input
        type="search"
        id="search"
        placeholder="Search transactions..."
        class="w-full md:w-1/3 border rounded-md p-2"
      />

      <div class="flex gap-4 w-full md:w-auto">
        <label class="sr-only" for="sort">Sort by</label>
        <select id="sort" class="border rounded-md p-2 w-full" aria-label="Sort by">
          <option value="latest">Latest</option>
          <option value="oldest">Oldest</option>
        </select>

        <label class="sr-only" for="category">Filter by category</label>
        <select
          id="category"
          class="border rounded-md p-2 w-full"
          aria-label="Filter by category"
        >
          <option value="all">All Transactions</option>
          <option value="general">General</option>
          <option value="personal-care">Personal Care</option>
          <option value="lifestyle">Lifestyle</option>
          <option value="transportation">Transportation</option>
        </select>
      </div>
    </div>
    <!-- Transactions Table (Desktop) -->
    <% if @transactions.any? %>
      <div class="hidden md:block">
        <table class="w-full text-left border-separate border-spacing-y-3">
          <thead class="text-sm text-neutral-500">
            <tr>
              <th>Recipient / Sender</th>
              <th>Category</th>
              <th>Transaction Date</th>
              <th class="text-right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% @transactions.each do |t| %>
              <tr>
                <td class="font-semibold">
                  <%= t.name %>
                </td>
                <td>
                  <%= t.category %>
                </td>
                <td>
                  <%= l(t.date, format: :short) %>
                </td>
                <td class="text-right text-red-600 font-semibold">
                  -$<%= t.amount %>
                </td>
              </tr>
              <tr>
                <td colspan="4">
                  <hr class="border-0 border-t border-gray-100 m-0 my-3">
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <!-- Transactions List (Mobile) -->
      <ul class="md:hidden flex flex-col divide-y divide-gray-100">

        <% @transactions.each do |t| %>
          <li class="p-4 flex justify-between items-center">

            <div>
              <p class="font-semibold">
                <%= t.name %>
              </p>
              <p class="text-sm text-neutral-500">
                <%= t.category %>
              </p>
            </div>
            <div class="text-right">
              <p class="text-red-600 font-semibold">
                -$<%= t.amount %>
              </p>
              <p class="text-sm text-neutral-500">
                <%= l(t.date, format: :short) %>
              </p>
            </div>
          </li>
        <% end %>
        <!-- Add more list items similarly -->
      </ul>
    <% else %>
      <p aria-label="No transactions found" class="text-center my-10">No transactions found.</p>
    <% end %>

  </section>
</div>
